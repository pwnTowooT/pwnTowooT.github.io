---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
import { getAllPosts } from '@/lib/data-utils'
import { Icon } from 'astro-icon/components'

const CATEGORIES = ['CS', 'Fuzzing', '1-day', 'Misc', 'Research', 'CTF']

const allPosts = await getAllPosts()

const categoryCounts = CATEGORIES.map((cat) => ({
  name: cat,
  count: allPosts.filter((post) => post.data.tags?.includes(cat)).length,
}))
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="Categories" />
  <Breadcrumbs items={[{ label: 'Categories', icon: 'lucide:folder-open' }]} />

  <div class="grid grid-cols-2 gap-3 sm:grid-cols-3">
    {
      categoryCounts.map(({ name, count }) => (
        <Link
          href={`/categories/${name}`}
          class="group flex flex-col items-center gap-2 rounded-xl border bg-muted/20 px-4 py-5 transition-all hover:border-accent/30 hover:bg-accent/5"
        >
          <Icon name="lucide:folder" class="size-5 text-accent/50 transition-colors group-hover:text-accent" />
          <span class="font-mono text-sm font-medium">{name}</span>
          <span class="text-xs text-muted-foreground">{count} posts</span>
        </Link>
      ))
    }
  </div>
</Layout>
